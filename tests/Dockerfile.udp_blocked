# Dockerfile.udp_blocked -- Runtime image for the UDP-blocked network test.
#
# Expects pre-built artifacts to be available via Docker build context.
# Run with: docker run --cap-add=NET_ADMIN ...
#
# Build:
#   docker build -f tests/Dockerfile.udp_blocked -t p2pav-udp-test .

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update -qq && apt-get install -y -qq --no-install-recommends \
        iptables \
        curl \
        python3 \
        openssl \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /opt/p2pav

# Copy pre-built shared library (resolve symlinks)
COPY build/src/p2p/libp2pav.so.1.0.0 /opt/p2pav/lib/libp2pav.so.1.0.0
RUN ln -sf libp2pav.so.1.0.0 /opt/p2pav/lib/libp2pav.so.1 && \
    ln -sf libp2pav.so.1 /opt/p2pav/lib/libp2pav.so

# Copy test binary
COPY build/tests/test_p2pav_udp_blocked /opt/p2pav/bin/

# Copy TLS certs (generated by host build script)
COPY build/certs/server.crt /opt/p2pav/certs/
COPY build/certs/server.key /opt/p2pav/certs/

# Copy entrypoint
COPY tests/docker_udp_blocked_entrypoint.sh /opt/p2pav/entrypoint.sh
RUN chmod +x /opt/p2pav/entrypoint.sh /opt/p2pav/bin/test_p2pav_udp_blocked

ENV LD_LIBRARY_PATH=/opt/p2pav/lib

ENTRYPOINT ["/opt/p2pav/entrypoint.sh"]
